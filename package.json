{
	"name": "@webitel/admin",
	"version": "26.6.0",
	"private": true,
	"scripts": {
		"dev": "vite --force",
		"build": "vite build",
		"preview": "npm run build && vite preview --base /",
		"test:unit": "vitest",
		"lint:fix": "npx biome check --write ./src",
		"lint:fix-staged": "npx lint-staged",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"tsc": "vue-tsc -p tsconfig.json",
		"utils:i": "npm i --install-links",
		"utils:up-libs": "npm up @webitel/api-services @webitel/ui-sdk @webitel/styleguide && npm run utils:ls-libs",
		"utils:ln-libs": "npm link @webitel/api-services @webitel/ui-sdk @webitel/styleguide && npm run utils:ls-libs",
		"utils:ls-libs": "npm ls @webitel/api-services @webitel/ui-sdk @webitel/styleguide",
		"prepare": "husky || true",
		"biome:ci:gh": "biome ci ./src --reporter=github",
		"test:unit:ci": "vitest run --coverage",
		"typecheck:ci": "true"
	},
	"type": "module",
	"dependencies": {
		"@vue/compat": "^3.5.x",
		"@vuelidate/core": "^2.0.3",
		"@vuelidate/validators": "^2.0.4",
		"@vueuse/core": "^14.x",
		"@webitel/api-services": "^0.1.46",
		"@webitel/styleguide": "~26.2",
		"@webitel/ui-sdk": "~26.6",
		"axios": "^1.18.1",
		"clipboard-copy": "^4.0.1",
		"cron-validator": "^1.4.0",
		"cronstrue": "^2.13.0",
		"date-fns": "^4.4.0",
		"deep-copy": "^1.4.2",
		"deep-equal": "^2.2.3",
		"deepmerge": "^4.2.2",
		"file-saver-es": "^2.0.5",
		"jszip": "^3.10.1",
		"jszip-utils": "^0.1.0",
		"lodash": "^4.17.21",
		"monaco-editor": "^0.55.1",
		"path": "^0.12.7",
		"pinia": "^2.3.1",
		"qrcode.vue": "^3.10.0",
		"qs-esm": "^7.0.2",
		"query-string": "^9.2.0",
		"sortablejs": "^1.15.7",
		"vidstack": "^1.15.6",
		"vue": "^3.5.x",
		"vue-i18n": "~11.x",
		"vue-router": "^4.4.3",
		"vue2-dropzone": "^3.6.0",
		"vuex": "^4.1.0",
		"webitel-sdk": "^26.4.15",
		"zod": "^4.x"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^22.10.10",
		"@vitejs/plugin-vue": "^6.x",
		"@vitest/coverage-v8": "^4.1.9",
		"@vue/test-utils": "^2.4.11",
		"@vue/tsconfig": "^0.9.1",
		"csv-parse": "^5.0.4",
		"globals": "^16.0.0",
		"happy-dom": "^20.10.6",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.0",
		"prismjs": "^1.29.0",
		"sass": "^1.101.0",
		"tslib": "^2.8.1",
		"typescript": "^5.6.3",
		"vite": "npm:rolldown-vite@^7.3.1",
		"vite-plugin-checker": "^0.14.4",
		"vite-plugin-node-polyfills": "^0.x",
		"vite-plugin-static-copy": "^3.1.4",
		"vite-plugin-vue-devtools": "^7.7.10",
		"vite-plugin-vue-docgen": "^0.3.4",
		"vitepress": "^1.4.3",
		"vitest": "^4.1.8",
		"vue-color": "^2.8.1",
		"vue-tsc": "^2.2.0"
	},
	"optionalDependencies": {
		"@esbuild/linux-x64": "0.28.1",
		"@rollup/rollup-linux-x64-gnu": "4.62.2"
	},
	"overrides": {
		"vue-tsc": "^2.2.0",
		"vite": "npm:rolldown-vite@^7.3.1"
	}
}
